{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/app",        "destination": "/api/serve-app" },
    { "source": "/app/(.*)",   "destination": "/api/serve-app" }
  ],
  "redirects": [
    { "source": "/app-content",      "destination": "/", "permanent": false },
    { "source": "/app-content.html", "destination": "/", "permanent": false }
  ],
  "functions": {
    "api/serve-app.js": {
      "includeFiles": "app-content.html"
    }
  },
  "headers": [
    {
      "source": "/app-content.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/admin.html",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
